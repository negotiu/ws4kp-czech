<%- include('header.ejs', {titleDual:{ top: 'Aktualní' , bottom: 'Podmínky' }, noaaLogo: false, hasTime: true}) %>
	<div class="main has-scroll has-box current-weather">
		<div class="weather template">
			<div class="left col">
				<div class="temp center"></div>
				<div class="condition center"></div>
				<div class="icon center"><img src="" /></div>
				<div class="wind-container">
					<div class="wind-label">Vítr:</div>
					<div class="wind"></div>
				</div>
				<div class="wind-gusts"></div>
			</div>
			<div class="right col">
				<div class="location"></div>
				<div class="row">
					<div class="label">Vlhkost:</div>
					<div class="humidity value"></div>
				</div>
				<div class="row">
					<div class="label">Rosný bod:</div>
					<div class="dewpoint value"></div>
				</div>
				<div class="row">
					<div class="label">Zákl. obl.:</div>
					<div class="ceiling value"></div>
				</div>
				<div class="row">
					<div class="label">Viditelnost:</div>
					<div class="visibility value"></div>
				</div>
				<div class="row">
					<div class="label">Tlak:</div>
					<div class="pressure value"></div>
				</div>
				<div class="row">
					<div class="label">Oblačnost:</div>
					<div class="cloud value"></div>
				</div>
				<div class="row">
					<div class="label">UV Index:</div>
					<div class="uv value"></div>
				</div>
				<div class="row">
					<div class="heat-index-label label"></div>
					<div class="heat-index value"></div>
				</div>
			</div>
		</div>
	</div>
	<%- include('scroll.ejs') %>